#!/bin/bash
commit_msg=$(git rev-parse --abbrev-ref HEAD)
commit_msg_pattern="^(feat|fix|docs|style|refactor|test|chore)(\([a-z]+\))?: .{10,}$"

echo "All arguments: $1"
echo "Executing before commit"

# Check if commit message matches the pattern
if ! [[ "$commit_msg" =~ $commit_msg_pattern ]]; then
    echo "COMMIT REJECTED: Commit message does not follow GitHub conventional commit format."
    echo "Expected format: <type>(<scope>): <description>"
    echo "Example: feat(ui): add button component"
    exit 1
fi

# Run Dart fix to automatically apply fixes
echo "Running Dart fix..."
if ! output=$(dart fix --apply); then
    echo "COMMIT REJECTED: Dart fix encountered errors:"
    echo "$output"
    exit 1
fi

# Run Dart format to ensure code is properly formatted
echo "Running Dart format..."
if ! output=$(dart format .); then
    echo "COMMIT REJECTED: Dart format encountered errors:"
    echo "$output"
    exit 1
fi

# Run Flutter analyze and check for errors
echo "Running Flutter analyze..."
if ! output=$(flutter analyze); then
    echo "COMMIT REJECTED: Flutter analyze found the following errors:"
    echo "$output"
    exit 1
fi

# Run Dart analyze and check for errors
echo "Running Dart analyze..."
if ! output=$(dart analyze); then
    echo "COMMIT REJECTED: Dart analyze found the following errors:"
    echo "$output"
    exit 1
fi

# If we made it this far, the commit is allowed
echo "Commit allowed!"
exit 0

